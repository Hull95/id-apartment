# --- Kontakt broj (Viber / WhatsApp / poziv) ---
# Postavi broj samo ovdje — sve linkove gradi sajt automatski.
# Međunarodni format BEZ + i razmaka (npr. BiH: 38765123456)
NEXT_PUBLIC_PHONE_INTL=38765000000
# Kako se broj prikazuje na sajtu
NEXT_PUBLIC_PHONE_DISPLAY=+387 65 000 000

# --- Booking.com iCal export link ---
# Booking Extranet -> Rates & Availability -> Sync Calendars -> Export your Calendar
# Bez ovog linka kalendar prikazuje sve kao slobodno.
BOOKING_ICAL_URL=

# Opcionalno: Airbnb iCal (ako stan postoji i tamo)
AIRBNB_ICAL_URL=
